{
  "name": "fleetweather",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @fleetweather/web dev",
    "dev:api": "pnpm --filter @fleetweather/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:migrate": "pnpm --filter @fleetweather/api db:migrate"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
