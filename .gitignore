# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (recursive — catches apps/*/node_modules, packages/*/node_modules)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/

# build output
.next/
out/
build/
dist/

# testing
coverage/

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore local env, but keep the committed template
.env
.env.*
!.env.example

# typescript / next
*.tsbuildinfo
next-env.d.ts

# misc
.DS_Store
Thumbs.db
*.pem

# editors
.vscode/*
!.vscode/extensions.json
.idea/

# deploy
.vercel
.agents

# HyperFrames video project — ignore generated/heavy artifacts, keep source
# (frames HTML, STORYBOARD.md, frame.md, index.html, assets/ stay tracked)
videos/**/renders/
videos/**/snapshots/
videos/**/.hyperframes/
videos/**/capture/
**/caption-skin.html.unused

# firecrawl scrape cache
.firecrawl/

# tool output caches
.lint*.json
.lint*.txt
.hf-dev.log